# Copy to .env for local runs. NEVER commit the real values.
# In GitHub Actions these come from repository secrets instead.

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Service role key — full write access, bypasses RLS. SERVER-SIDE ONLY.
SUPABASE_SERVICE_KEY=your-service-role-key

# Free LLM provider for structuring updates.
# Default below targets Groq (OpenAI-compatible, generous free tier): https://console.groq.com
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
