# Copy to .env.local and fill in.

# PUBLIC (read-only anon/publishable key) — safe in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVER-ONLY (no NEXT_PUBLIC prefix — never sent to the browser).
# Powers the detail popup's AI-generated brief.
LLM_API_KEY=your-groq-api-key
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Web search grounding so the popup's facts are genuine + citable.
# Free key at https://app.tavily.com. Optional — without it the brief uses model knowledge only.
TAVILY_API_KEY=your-tavily-api-key
